{
  "version": 2,
  "name": "videolens",
  "functions": {
    "api/index.js": {
      "includeFiles": "**/.env*",
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
